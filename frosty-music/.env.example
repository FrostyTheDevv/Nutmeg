# ========================================
# Discord Bot Configuration
# ========================================
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here

# Environment
NODE_ENV=production

# ========================================
# Lavalink Configuration (Remote Server)
# ========================================
# Use your Railway Lavalink service URL (without http://)
LAVALINK_HOST=lavalink-production-xxxx.up.railway.app
LAVALINK_PORT=443
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_PASS=youshallnotpass
LAVALINK_SECURE=true
LAVALINK_NODE_ID=Railway-Node

# ========================================
# Optional: Spotify Support
# ========================================
# SPOTIFY_CLIENT_ID=your_spotify_client_id
# SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ========================================
# Optional: Genius Lyrics
# ========================================
# GENIUS_API_TOKEN=your_genius_api_token
